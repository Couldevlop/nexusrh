{
  "name": "@nexusrhci/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=../../.env src/index.ts",
    "kill-port": "node -e \"const {execSync}=require('child_process');try{const out=execSync('netstat -ano').toString();out.split('\\n').filter(l=>l.includes(':4001')&&l.includes('LISTENING')).forEach(l=>{const pid=l.trim().split(/\\s+/).pop();try{execSync('taskkill /F /PID '+pid);}catch(e){}});}catch(e){}console.log('port 4001 cleared')\"",
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@elastic/elasticsearch": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/oauth2": "^7.7.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@fastify/websocket": "^8.3.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.4",
    "drizzle-orm": "^0.31.2",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "mjml": "^4.15.3",
    "nodemailer": "^6.9.14",
    "otplib": "^12.0.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/mjml": "^4.7.4",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^6.4.15",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.6",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.22.7",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
