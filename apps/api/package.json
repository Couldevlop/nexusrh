{
  "name": "@nexusrh/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:migrate-parameters": "tsx src/db/migrate-parameters.ts",
    "db:migrate-validation": "tsx src/db/migrate-validation-level.ts",
    "admin:reset": "tsx src/scripts/reset-tenant-admin.ts",
    "db:seed-params": "tsx src/scripts/seed-parameters.ts",
    "test:upload": "tsx src/scripts/test-document-upload.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@aws-sdk/client-s3": "^3.583.0",
    "@aws-sdk/s3-request-presigner": "^3.583.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/oauth2": "^7.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@fastify/websocket": "^10.0.1",
    "@nexusrh/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.2",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "form-data": "^4.0.5",
    "meilisearch": "^0.41.0",
    "mjml": "^4.15.3",
    "nodemailer": "^6.9.14",
    "otplib": "^12.0.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1",
    "qrcode": "^1.5.4",
    "redis": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/mjml": "^4.7.4",
    "@types/nodemailer": "^6.4.15",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.6",
    "@types/qrcode": "^1.5.5",
    "drizzle-kit": "^0.22.7",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
