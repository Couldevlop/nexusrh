# ══════════════════════════════════════════════════════════════════════════════
# NexusRH — Configuration déploiement 100% GRATUIT
# Stack : Neon (PG) + Upstash (Redis) + Cloudflare R2 (Storage) + Fly.io (API)
# ══════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
APP_NAME=NexusRH

# ── URLs ───────────────────────────────────────────────────────────────────────
# Remplacer par vos URLs Fly.io et Cloudflare Pages après déploiement
APP_URL=https://nexusrh.pages.dev            # Cloudflare Pages
API_URL=https://nexusrh-api.fly.dev          # Fly.io API
API_PORT=4000
LOG_LEVEL=info

# ── Base de données — Neon (PostgreSQL serverless, GRATUIT) ───────────────────
# Créer sur https://neon.tech → New Project → copier la "Connection string"
# Format : postgresql://user:pass@ep-xxx.region.aws.neon.tech/nexusrh?sslmode=require
DATABASE_URL=postgresql://nexusrh_owner:xxxxxxxxxxxx@ep-cool-name-123456.eu-central-1.aws.neon.tech/nexusrh?sslmode=require

# Pool Neon : réduire car serverless suspend la DB (connexions = courte durée)
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5

# ── Cache / Queue — Upstash Redis (GRATUIT 10k req/jour) ─────────────────────
# Créer sur https://upstash.com → Create Database → Redis → copier l'URL
# Format : rediss://default:xxxxxxxxxxxx@xxx.upstash.io:6379
REDIS_URL=rediss://default:xxxxxxxxxxxx@gusc1-xxx-34567.upstash.io:6379

# ── Sécurité JWT ──────────────────────────────────────────────────────────────
# Générer : openssl rand -base64 48
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_LONG_HERE
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
MFA_ISSUER=NexusRH

# ── IA (optionnel) ────────────────────────────────────────────────────────────
# Sans cette clé, l'assistant IA sera désactivé — tout le reste fonctionne
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# ── Email — Gmail App Password (GRATUIT) ─────────────────────────────────────
# 1. Activer "Validation en 2 étapes" sur votre compte Google
# 2. https://myaccount.google.com/apppasswords → NexusRH → Générer
# 3. Copier le mot de passe à 16 caractères (espaces inclus)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=NexusRH <votre.email@gmail.com>

# ── Stockage fichiers — Cloudflare R2 (GRATUIT 10GB) ─────────────────────────
# Créer sur https://dash.cloudflare.com → R2 → Create bucket "nexusrh"
# API Tokens → Create token → R2 Token → Read+Write → copier Access Key ID + Secret
# Account ID : visible dans le dashboard Cloudflare (URL ou sidebar)
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET=nexusrh
S3_REGION=auto
S3_FORCE_PATH_STYLE=true

# ── Recherche — Fallback PostgreSQL (pas de Meilisearch nécessaire) ───────────
# Laisser vide pour utiliser la recherche PostgreSQL full-text (GRATUIT)
# Ou renseigner si vous avez un Meilisearch (Render free tier par exemple)
MEILISEARCH_URL=
MEILISEARCH_MASTER_KEY=

# ── OAuth (optionnel) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://nexusrh-api.fly.dev/auth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=https://nexusrh-api.fly.dev/auth/microsoft/callback

# ── Feature flags ─────────────────────────────────────────────────────────────
FEATURE_AI_ASSISTANT=false        # Désactiver si pas de clé Anthropic
FEATURE_PREDICTIVE_ANALYTICS=true
FEATURE_ELECTRONIC_SIGNATURE=true # Mode démo si pas de clé YouSign
FEATURE_MULTI_COUNTRY=false
FEATURE_KIOSK_MODE=true
